<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Joyeux anniversaire</title>

<style>
body {
    margin: 0;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background: linear-gradient(135deg, #1e1e2f, #2c2c54);
    font-family: 'Segoe UI', sans-serif;
}

/* Enveloppe */
.envelope {
    position: relative;
    width: 320px;
    height: 220px;
    background: #f5f5f5;
    border-radius: 8px;
    cursor: pointer;
    box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    overflow: hidden;
}

/* Rabat */
.flap {
    position: absolute;
    width: 100%;
    height: 100%;
    background: #e0e0e0;
    clip-path: polygon(0 0, 50% 60%, 100% 0);
    transition: transform 1s ease;
    transform-origin: top;
    z-index: 2;
}

/* Lettre */
.letter {
    position: absolute;
    width: 90%;
    height: 90%;
    background: white;
    top: 5%;
    left: 5%;
    border-radius: 6px;
    display: flex;
    justify-content: center;
    align-items: center;
    transform: translateY(100%);
    transition: transform 1s ease;
    z-index: 1;
}

.letter h1 {
    font-size: 1.5em;
    color: #ff4d6d;
    text-align: center;
}

/* Sceau coeur */
.seal {
    position: absolute;
    width: 60px;
    height: 60px;
    background: #ff4d6d;
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    display: flex;
    justify-content: center;
    align-items: center;
    animation: glow 2s infinite;
}

/* coeur */
.seal::before {
    content: "❤";
    color: white;
    font-size: 24px;
}

/* effet scintillement */
@keyframes glow {
    0% { box-shadow: 0 0 5px #ff4d6d; }
    50% { box-shadow: 0 0 20px #ff4d6d; }
    100% { box-shadow: 0 0 5px #ff4d6d; }
}

/* Etat ouvert */
.open .flap {
    transform: rotateX(180deg);
}

.open .letter {
    transform: translateY(0);
}

.open .seal {
    opacity: 0;
    transition: opacity 0.5s;
}

/* Responsive */
@media (max-width: 400px) {
    .envelope {
        width: 260px;
        height: 180px;
    }

    .letter h1 {
        font-size: 1.2em;
    }
}
</style>
</head>

<body>

<div class="envelope" onclick="openLetter()">
    <div class="flap"></div>
    <div class="letter">
        <h1>Joyeux anniversaire mon chat ❤️</h1>
    </div>
    <div class="seal"></div>
</div>

<script>
function openLetter() {
    document.querySelector('.envelope').classList.add('open');
}
</script>

</body>
</html>
